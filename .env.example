# ==============================================================================
# CIVICAI INDIA — Environment Configuration
# Copy this file to .env and fill in the values before running the project.
# ==============================================================================

# ============================================================================
# DJANGO CORE
# ============================================================================
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-super-secret-key-here-change-this-in-production

# Set to False in production
DJANGO_DEBUG=False

# Comma-separated. Add your Render/Railway domain when deploying.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-app-name.onrender.com

# ============================================================================
# DATABASE (PostgreSQL — provided by Render/Railway free tier)
# ============================================================================
# Format: postgresql://user:password@host:port/database
# Render auto-injects this as DATABASE_URL — no manual setup needed there.
DATABASE_URL=postgresql://user:password@localhost:5432/civicai_db

# ============================================================================
# IMAGE STORAGE — Cloudinary free tier (25 GB storage, 25 GB bandwidth/month)
# Sign up free at: https://cloudinary.com
# ============================================================================
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============================================================================
# AI — Google Gemini (free tier: 15 RPM, 1M TPM)
# Get key at: https://aistudio.google.com/app/apikey
# ============================================================================
GEMINI_API_KEY=your-google-gemini-api-key-here

# ============================================================================
# ADMIN PANEL
# ============================================================================
ADMIN_PANEL_USERNAME=admin
ADMIN_PANEL_PASSWORD=change-this-strong-password

# ============================================================================
# CORS & SECURITY
# ============================================================================
CORS_ALLOWED_ORIGINS=https://your-app-name.onrender.com

# ============================================================================
# ERROR TRACKING (optional — Sentry free tier)
# Sign up at: https://sentry.io
# ============================================================================
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ============================================================================
# EMAIL (optional)
# ============================================================================
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=noreply@civicai.in

# ============================================================================
# MISC
# ============================================================================
ENVIRONMENT=production
DJANGO_LOG_LEVEL=INFO
